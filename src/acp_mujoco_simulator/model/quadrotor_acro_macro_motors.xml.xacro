<?xml version="1.0"?>
<!--
  Quadrotor macro CON modelo de motores realista (gemelo digital)
  
  Misma geometría y masa que quadrotor_acro_macro.xml.xacro,
  pero el plugin AcroMode se configura con motor_model="true"
  y los parámetros del motor/hélice.

  ╔══════════════════════════════════════════════════════════════╗
  ║  PARÁMETROS A CALIBRAR CON TU DRONE REAL                   ║
  ╠══════════════════════════════════════════════════════════════╣
  ║  arm_length      Distancia centro → motor [m]     (0.1)    ║
  ║  kf              Coef. thrust  F=kf·ω²  [N/(rad/s)²]      ║
  ║  km              Coef. torque  τ=km·ω²  [N·m/(rad/s)²]    ║
  ║  motor_tau       Const. tiempo motor [s]           (0.02)  ║
  ║  motor_omega_max Vel. angular max motor [rad/s]    (2500)  ║
  ║  drag_coeff      Coef. drag aerodinámico [N/(m/s)] (0.1)   ║
  ╚══════════════════════════════════════════════════════════════╝

  Valores típicos por defecto para un quad de ~5" / 1 kg.
  kf y km se calcularon para que:
    - hover thrust ≈ 10.6 N con 4 motores → cada motor 2.65 N
    - ω_hover = sqrt(2.65 / 1.91e-6) ≈ 1178 rad/s  (~11250 RPM)
    - ω_max  = 2500 rad/s  (~23900 RPM, relación thrust/weight ≈ 4.5:1)
-->
<mujoco xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="quadrotor_body" params="prefix pos euler:='0 0 0'">
    <body name="${prefix}" pos="${pos}" euler="${euler}">
      <joint name="${prefix}" type="free" damping="0.001" armature="0" pos="0 0 0"/>
      
      <geom name="${prefix}_core" type="box" size="0.035 0.035 0.015" rgba="1.0 1.0 0.0 1.0" mass=".85"/>
      <site name="${prefix}_imu" pos="0 0 0"/>
      
      <geom name="${prefix}_a00" type="box" pos=".071 0.071 0.0" size="0.05 0.01 0.0025" quat=".924 0 0 0.383" rgba="1 0.5 0 1" mass=".035"/>
      <geom name="${prefix}_a10" type="box" pos=".071 -0.071 0.0" size="0.05 0.01 0.0025" quat=".383 0 0 0.924" rgba="1 0.5 0 1" mass=".035"/>
      <geom name="${prefix}_a20" type="box" pos="-0.071 -0.071 0.0" size="0.05 0.01 0.0025" quat="-.383 0 0 0.924" rgba="1 0.5 0 1" mass=".035"/>
      <geom name="${prefix}_a30" type="box" pos="-.071 0.071 0.0" size="0.05 0.01 0.0025" quat=".924 0 0 -0.383" rgba="1 0.5 0 1" mass=".035"/>

      <!-- Motor housings (same as original) -->
      <geom name="${prefix}_thruster00" type="cylinder" pos="0.1 0.1 0.01" size="0.03 0.0025" quat="1.0 0.0 0.0 0." rgba="0.0 0.0 0.0 1.0" mass=".012"/>
      <geom name="${prefix}_thruster10" type="cylinder" pos="0.1 -0.1 0.01" size="0.03 0.0025" quat="1.0 0.0 0.0 0." rgba="0.0 0.0 0.0 1.0" mass=".012"/>
      <geom name="${prefix}_thruster20" type="cylinder" pos="-0.1 -0.1 0.01" size="0.03 0.0025" quat="1.0 0.0 0.0 0." rgba="0.0 0.0 0.0 1.0" mass=".012"/>
      <geom name="${prefix}_thruster30" type="cylinder" pos="-0.1 0.1 0.01" size="0.03 0.0025" quat="1.0 0.0 0.0 0." rgba="0.0 0.0 0.0 1.0" mass=".012"/>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!--  PROPELLERS: visual spinning blades driven by plugin   -->
      <!--  Each propeller is a child body with a free-spin hinge -->
      <!--  joint on the Z axis. The plugin sets qvel to match    -->
      <!--  the motor angular velocity for visual fidelity.       -->
      <!--                                                        -->
      <!--  Betaflight X-config:                                  -->
      <!--    M1 (front-right, +x,-y) CW                         -->
      <!--    M2 (rear-right,  -x,-y) CCW                        -->
      <!--    M3 (rear-left,   -x,+y) CW                         -->
      <!--    M4 (front-left,  +x,+y) CCW                        -->
      <!--                                                        -->
      <!--  Blade geoms: 2 rectangular blades (cross) per prop    -->
      <!--  Mass: 0.003 kg each (total 0.012 kg for 4 props)     -->
      <!-- ═══════════════════════════════════════════════════════ -->

      <!-- Propeller 1: front-right (CW) -->
      <body name="${prefix}_prop1" pos="0.1 -0.1 0.015">
        <joint name="${prefix}_prop1_spin" type="hinge" axis="0 0 1" frictionloss="0.0001" damping="0.00001" armature="1e-6"/>
        <geom name="${prefix}_blade1a" type="box" pos="0 0 0" size="0.055 0.008 0.001" rgba="0.2 0.2 0.2 0.7" mass="0.0015" contype="0" conaffinity="0"/>
        <geom name="${prefix}_blade1b" type="box" pos="0 0 0" size="0.008 0.055 0.001" rgba="0.2 0.2 0.2 0.7" mass="0.0015" contype="0" conaffinity="0"/>
      </body>

      <!-- Propeller 2: rear-right (CCW) -->
      <body name="${prefix}_prop2" pos="-0.1 -0.1 0.015">
        <joint name="${prefix}_prop2_spin" type="hinge" axis="0 0 1" frictionloss="0.0001" damping="0.00001" armature="1e-6"/>
        <geom name="${prefix}_blade2a" type="box" pos="0 0 0" size="0.055 0.008 0.001" rgba="0.3 0.3 0.9 0.7" mass="0.0015" contype="0" conaffinity="0"/>
        <geom name="${prefix}_blade2b" type="box" pos="0 0 0" size="0.008 0.055 0.001" rgba="0.3 0.3 0.9 0.7" mass="0.0015" contype="0" conaffinity="0"/>
      </body>

      <!-- Propeller 3: rear-left (CW) -->
      <body name="${prefix}_prop3" pos="-0.1 0.1 0.015">
        <joint name="${prefix}_prop3_spin" type="hinge" axis="0 0 1" frictionloss="0.0001" damping="0.00001" armature="1e-6"/>
        <geom name="${prefix}_blade3a" type="box" pos="0 0 0" size="0.055 0.008 0.001" rgba="0.2 0.2 0.2 0.7" mass="0.0015" contype="0" conaffinity="0"/>
        <geom name="${prefix}_blade3b" type="box" pos="0 0 0" size="0.008 0.055 0.001" rgba="0.2 0.2 0.2 0.7" mass="0.0015" contype="0" conaffinity="0"/>
      </body>

      <!-- Propeller 4: front-left (CCW) -->
      <body name="${prefix}_prop4" pos="0.1 0.1 0.015">
        <joint name="${prefix}_prop4_spin" type="hinge" axis="0 0 1" frictionloss="0.0001" damping="0.00001" armature="1e-6"/>
        <geom name="${prefix}_blade4a" type="box" pos="0 0 0" size="0.055 0.008 0.001" rgba="0.3 0.3 0.9 0.7" mass="0.0015" contype="0" conaffinity="0"/>
        <geom name="${prefix}_blade4b" type="box" pos="0 0 0" size="0.008 0.055 0.001" rgba="0.3 0.3 0.9 0.7" mass="0.0015" contype="0" conaffinity="0"/>
      </body>

      <site name="${prefix}_thrust" type="box" pos="0 0 0" size="0.035 0.035 0.015" rgba="0 1 1 1"/>
      <site name="${prefix}_rateX" type="box" pos="0 0 0" size="0.035 0.035 0.015" rgba="0 1 1 1"/>
      <site name="${prefix}_rateY" type="box" pos="0 0 0" size="0.035 0.035 0.015" rgba="0 1 1 1"/>
      <site name="${prefix}_rateZ" type="box" pos="0 0 0" size="0.035 0.035 0.015" rgba="0 1 1 1"/>

      <site name="${prefix}_payload_site" pos="0.0 0.0 -0.05"/>
      
      <camera name="${prefix}_camera" pos="0.035 0 -0.015" euler="0 0 -1.57"/>
    </body>
  </xacro:macro>

  <xacro:macro name="quadrotor_physical_sensors" params="prefix">
    <accelerometer name="${prefix}_accel" site="${prefix}_imu" />
    <gyro name="${prefix}_gyro" site="${prefix}_imu" />
  </xacro:macro>


  <xacro:macro name="quadrotor_actuators" params="prefix">
    <!-- Actuators: same as original — wrench applied to body -->
    <motor site="${prefix}_thrust" name="${prefix}_body_thrust" ctrllimited="true" ctrlrange="0 82.0" gear="0 0 1 0 0 0"/>
    <motor site="${prefix}_rateX"  name="${prefix}_x_moment" ctrllimited="true" ctrlrange="-0.3 0.3" gear="0 0 0 1 0 0"/>
    <motor site="${prefix}_rateY"  name="${prefix}_y_moment" ctrllimited="true" ctrlrange="-0.3 0.3" gear="0 0 0 0 1 0"/>
    <motor site="${prefix}_rateZ"  name="${prefix}_z_moment" ctrllimited="true" ctrlrange="-0.3 0.3" gear="0 0 0 0 0 1"/>
    
    <!--
      AcroMode plugin with MOTOR MODEL enabled.
      The plugin still receives [F, ωd] via ROS2 trpy_cmd,
      runs the rate controller, then passes the desired wrench
      through the motor model before writing to MuJoCo actuators.
      
      Adjust these values to match your real drone:
    -->
    <plugin name="acro_ctrl_${prefix}" plugin="MujocoRosUtils::AcroMode" joint="${prefix}">
      <config key="actuator_fz"      value="${prefix}_body_thrust"/>
      <config key="actuator_tx"      value="${prefix}_x_moment"/>
      <config key="actuator_ty"      value="${prefix}_y_moment"/>
      <config key="actuator_tz"      value="${prefix}_z_moment"/>
      <config key="control_hz"       value="500"/>
      <config key="body_name"        value="${prefix}"/>

      <!-- ═══ Motor model ON ═══ -->
      <config key="motor_model"      value="true"/>

      <!-- Geometry -->
      <config key="arm_length"       value="0.1"/>

      <!-- Propeller: F=kf*w², τ=km*w² -->
      <config key="kf"               value="1.91e-6"/>
      <config key="km"               value="2.6e-8"/>

      <!-- Motor dynamics -->
      <config key="motor_tau"        value="0.02"/>
      <config key="motor_omega_max"  value="2500.0"/>

      <!-- Aerodynamic drag -->
      <config key="drag_coeff"       value="0.1"/>
    </plugin>
  </xacro:macro>

  <xacro:macro name="quadrotor_sensor_plugins" params="prefix">
    <plugin name="${prefix}_odom" plugin="MujocoRosUtils::OdometryPublisher" objtype="xbody" objname="${prefix}">
      <config key="publish_rate" value="240"/>
    </plugin>
    <plugin name="${prefix}_imu_pub" plugin="MujocoRosUtils::ImuPublisher">
      <config key="body_name"    value="${prefix}"/>
      <config key="accel_sensor" value="${prefix}_accel"/>
      <config key="gyro_sensor"  value="${prefix}_gyro"/>
      <config key="publish_rate" value="200"/>
    </plugin>
  </xacro:macro>
</mujoco>
